{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Dev Server",
            "type": "npm",
            "script": "start",
            "group": "build",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Run E2E Tests",
            "type": "npm",
            "script": "test:e2e",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Create Post",
            "type": "npm",
            "script": "post:create",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Generate Featured Image",
            "type": "process",
            "command": "node",
            "args": [
                "scripts/generate-featured-image.mjs",
                "--file",
                "${file}",
                "--prompt",
                "${input:featuredImagePrompt}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "featuredImagePrompt",
            "type": "promptString",
            "description": "Describe the featured image you want OpenAI to generate"
        }
    ]
}
